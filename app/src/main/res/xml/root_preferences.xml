<PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <PreferenceCategory app:title="Rate type">

        <ListPreference
            app:key="rate_type"
            app:title="Rate type"
            app:entries="@array/feature_names"
            app:entryValues="@array/feature_values"
            app:defaultValue="api_rate"
            app:useSimpleSummaryProvider="true"
            />

        <EditTextPreference
            app:key="rate_amount"
            app:title="Rate"
            app:defaultValue="0"
            app:useSimpleSummaryProvider="true"
            />
    </PreferenceCategory>

</PreferenceScreen>